<h2 class="fw-bolder text-neutral-2 mt-3 mb-3 face-id" data-face="{{id}}">Face {{id}} details</h2>

<div class="card-info d-flex flex-column-reverse flex-sm-row justify-content-between align-items-center align-items-sm-start">
    <form class="card-form" style="width: 100%; max-width: 600px;">
        <div class="form-group d-flex flex-column flex-sm-row align-items-start align-items-sm-center justify-content-between">
            <label for="face-id-input" class="fw-bold text-neutral-2">Face ID</label>
            <input type="text" class="form-control rounded-13 shadow-c-1" id="face-id-input" disabled>
        </div>

        <div class="form-group d-flex flex-column flex-sm-row align-items-start flex-sm-row align-items-sm-center justify-content-between mt-3">
            <label for="face-name" class="fw-bold text-neutral-2">Face Name</label>
            <input type="text" class="form-control rounded-13" name="faceName" id="face-name">
        </div>

        <div class="form-group d-flex align-items-start align-items-sm-center justify-content-start mt-3">
            <label class="form-check-label fw-bold text-neutral-2 me-3" for="auth-type">Two Step Authentication</label>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="auth-type">
            </div>
        </div>

        <div class="form-group d-flex flex-row align-items-start align-items-sm-center justify-content-end mt-3">
            <p class="text-center text-blue-3 pointer me-3 bg-blue-2 py-1 px-3 rounded-13 fw-bold" id="save-change">Save Change</p>
        </div>
    </form>

    <div class="mb-5 mb-sm-0 text-center">
        <div class="rounded-13 shadow-sm border border-light p-2" style="width: 260px; height: 260px; background: #e9ecef; display: flex; align-items: center; justify-content: center;">
            <img src="" alt="User Face" id="user-profile-img" class="face-icon" style="width: 100px; height: 100px; object-fit: cover; border-radius: 50%;">
        </div>
    </div>
</div>

<h2 class="fw-bolder mt-5 text-neutral-2 mb-4">Your face history</h2>
<div class="row bg-neutral-7 p-2 rounded-10 mb-3">
    <div class="col-3"><p class="fw-bold text-neutral-2 mb-0">No</p></div>
    <div class="col-3"><p class="fw-bold text-neutral-2 mb-0">Room</p></div>
    <div class="col-3"><p class="fw-bold text-neutral-2 mb-0">Datetime</p></div>
    <div class="col-3"><p class="fw-bold text-neutral-2 mb-0">Status</p></div>
</div>

<div class="shadow log-container"></div>
<p class="text-center mt-3 pointer py-2 rounded-13 bg-neutral-6" id="load-more">Load More</p>