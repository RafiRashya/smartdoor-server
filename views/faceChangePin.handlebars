<h3 class="fw-bold text-neutral-2 mt-3 mb-4">Change User PIN</h3>

<form
    class="card-change-pin align-items-center flex-column bg-neutral-6 shadow-c-1 p-4 p-sm-5 pb-5 rounded-13 d-flex mb-5"
    data-face-id="{{id}}" data-user-id="{{userId}}">
    <img src="/image/illustration-user.png" alt="User Face" class="card-icon mb-3" style="width: 100px; height: 100px; object-fit: cover; border-radius: 50%;">
    <small id="user-info">Username: {{username}}</small>

    <div class="form-group mt-3 d-flex flex-column flex-sm-row align-items-start align-items-sm-center justify-content-between">
        <label for="new-pin" class="fw-bold text-neutral-2 me-4">New PIN</label>
        <input type="password" pattern="[0-9]*" inputmode="numeric" autocomplete="on" class="form-control rounded-13 shadow-c-1" name="newPin" id="new-pin" maxlength="6">
    </div>

    <div class="form-group mt-3 d-flex flex-column flex-sm-row align-items-start align-items-sm-center justify-content-between">
        <label for="confirm-pin" class="fw-bold text-neutral-2 me-4">Confirm PIN</label>
        <input type="password" pattern="[0-9]*" inputmode="numeric" autocomplete="on" class="form-control rounded-13 shadow-c-1" name="confirmPin" maxlength="6" id="confirm-pin">
    </div>
    <p class="text-danger-1 fw-bold mt-3" id="is-new-pin-match"></p>

    <button class="btn p-2 mt-4 rounded-13 bg-blue-3 text-neutral-7 fw-bold" id="save" disabled>Change PIN</button>
</form>
